# Copy to `.env` for local development or inject via your deployment platform.

# --- LLM provider ---
# Preferred generic variables:
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Compatibility variable still supported by parts of the codebase:
DEEPSEEK_API_KEY=

# --- Database ---
# Local dev: localhost | Docker: mysql_db | remote: internal host or managed DB endpoint
DB_HOST=mysql_db
DB_PORT=3306
DB_USER=geo_app
DB_PASSWORD=change-this-password
DB_NAME=geo_engine
MYSQL_ROOT_PASSWORD=change-this-root-password

# --- Optional publishers ---
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- Runtime ---
OTEL_SDK_DISABLED=true
MYSQL_CONNECTOR_PYTHON_TELEMETRY=0
TZ=Asia/Shanghai

# --- Target profile (generic mode) ---
TARGET_ENTITY_NAME=目标组织
TARGET_ENTITY_ALIASES=目标组织,目标品牌
TARGET_CAPABILITY_NOUN=组织能力

# --- Feedback loop ---
ENABLE_ACTIVE_PROBING=false
ACTIVE_PROBE_PLATFORMS=kimi,doubao,deepseek
