# ============================================================
# gitgeo — 开源 GEO 引擎环境配置
# 复制为 .env 后按需修改
# cp .env.example .env
# ============================================================

# --- LLM 提供商（至少填一组）---
# 推荐使用 GEO_LLM_* 统一变量，兼容任意 OpenAI 兼容 API
GEO_LLM_API_KEY=sk-your-key-here
GEO_LLM_BASE_URL=https://api.deepseek.com
GEO_LLM_MODEL=deepseek-chat

# 以下是旧变量兼容（可留空，系统会自动回退到 GEO_LLM_*）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# DEEPSEEK_API_KEY=

# --- 数据库 ---
DB_HOST=mysql_db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=geo_knowledge_engine
MYSQL_ROOT_PASSWORD=root_password

# --- 可选：品牌/组织配置 ---
# GEO_SITE_NAME=我的站点
# GEO_SITE_DOMAIN=example.com
# GEO_ORG_NAME=我的组织
# TARGET_ENTITY_NAME=目标组织
# TARGET_ENTITY_ALIASES=目标组织,目标品牌
# TARGET_CAPABILITY_NOUN=组织能力

# --- 可选：反馈闭环 ---
# GEO_ENABLE_PROBING=false
# GEO_PROBE_PLATFORMS=deepseek,kimi,doubao

# --- 可选：发布渠道 ---
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# --- 运行时（一般不需改）---
OTEL_SDK_DISABLED=true
MYSQL_CONNECTOR_PYTHON_TELEMETRY=0
TZ=Asia/Shanghai
